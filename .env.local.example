# Spirit OS — Project Hub & Mission Briefing
# Copy this file to .env.local and fill in your values.

# Optional: hostnames allowed to load Next dev HMR (`/_next/webpack-hmr`). Comma-separated, no protocol/port.
# Restart `npm run dev` after changing this — next.config reads it at startup.
# NEXT_ALLOWED_DEV_ORIGINS=10.0.0.186,100.111.32.31,my-host.ts.net
#
# Optional: comma-separated IPs/hostnames for scripts/gen-dev-cert.sh (LAN + Tailscale MagicDNS).
# SPIRIT_TLS_EXTRA_HOSTS=10.0.0.186,100.111.32.31,my-host.tail-scale.ts.net

# Comma-separated list of absolute project paths on Node 2.
# Single path (legacy):  SPIRIT_PROJECT_PATH=/mnt/spirit-projects/my-project
# Multi-project:         SPIRIT_PROJECT_PATH=/mnt/spirit-projects/project-a,/mnt/spirit-projects/project-b
SPIRIT_PROJECT_PATH=/mnt/spirit-projects/your-project-folder-name

# Ollama HTTP API (Next `/api/spirit` reads OLLAMA_BASE_URL). Keep in sync with OLLAMA_HOST if you use both.
OLLAMA_BASE_URL=http://localhost:11434
# Legacy alias for other tooling.
OLLAMA_HOST=http://localhost:11434

# Optional: full OpenAI-compat base for Spirit chat (e.g. http://host:11434/v1). Usually leave blank.
OLLAMA_OPENAI_BASE_URL=
OLLAMA_API_KEY=ollama

# Ollama model tag for `/api/spirit` (default in code: hermes4). Pull on the Ollama host: `ollama pull hermes4`.
OLLAMA_MODEL=hermes4

# Optional: `/oracle` uses ORACLE_OLLAMA_MODEL when set; otherwise same as OLLAMA_MODEL.
# ORACLE_OLLAMA_MODEL=hermes3:8b
# ORACLE_MAX_OUTPUT_TOKENS=768

# Whisper STT (docker `spirit-whisper` / OpenAI-style transcriptions) — Next `/api/stt/transcribe` proxies here.
# Defaults match `backend/docker-compose.yml` (host port 8000, path /v1/audio/transcriptions).
# WHISPER_STT_URL=http://localhost:8000
# WHISPER_STT_TRANSCRIBE_PATH=/v1/audio/transcriptions
# WHISPER_STT_MODEL=whisper-1

# Max tokens per assistant reply from `/api/spirit`; defaults to 1024 if unset.
SPIRIT_MAX_OUTPUT_TOKENS=1024

# Optional: context slots on the Ollama host when configured there. Unset → UI shows “Host default”.
# OLLAMA_NUM_CTX=8192

# TTS_PROVIDER=piper | elevenlabs
TTS_PROVIDER=piper

# Piper TTS (openedai-speech) — local OpenAI-compatible speech API.
PIPER_TTS_URL=http://localhost:5200
PIPER_TTS_VOICE=fable

# ElevenLabs (optional; set TTS_PROVIDER=elevenlabs and add key)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=fgDJOgmENIR82PueQrVs
# ELEVENLABS_DEFAULT_VOICE_ID=
# ELEVENLABS_DEFAULT_VOICE_NAME=Clarice
# Explicit allowlist (recommended — no catalog read needed): ids ~10+ chars after last colon.
# ELEVENLABS_VOICE_ALLOWLIST=Clarice:your_voice_id_here,Charlotte:other_id_here
# Name-only (needs catalog + key): if catalog fails, use Name:voice_id instead.
# ELEVENLABS_VOICE_ALLOWLIST=Charlotte,Clarice,Minerva Nightshade,Paige
# ELEVENLABS_VOICE_ALLOWLIST_JSON=[{"name":"Clarice","voice_id":"..."}]
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# ElevenLabs voice_settings.speed default (0.7–1.2); Voice settings UI can override per request.
# ELEVENLABS_VOICE_SPEED=1.12

# Prompt 10B — OpenAI web search (Researcher + POST /api/research/web-search)
# OPENAI_API_KEY=sk-...
# WEB_SEARCH_ENABLED=true
# WEB_SEARCH_MODEL=gpt-4o
