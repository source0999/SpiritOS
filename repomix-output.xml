      if (el.scrollTop > 12) return;
      const now = Date.now();
      if (now - last < 320) return;
      last = now;
      const t = e.touches[0];
      fetch("http://localhost:7530/ingest/da155463-47fd-4bed-94cb-233903115f13", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-Debug-Session-Id": "d22b1b",
