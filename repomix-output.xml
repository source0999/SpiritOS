    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
  }
  .homelab-badge--live {
    color: oklch(0.74 0.16 160);
    background: oklch(0.74 0.16 160 / 0.10);
    border-color: oklch(0.74 0.16 160 / 0.30);
  }
  .homelab-badge--live::before {
    animation: hl-badge-pulse 1.6s ease-out infinite;
    box-shadow: 0 0 0 0 currentColor;
  }
  .homelab-badge--pending {
    color: oklch(0.80 0.16 80);
    background: oklch(0.80 0.16 80 / 0.10);
    border-color: oklch(0.80 0.16 80 / 0.28);
  }
  .homelab-badge--mock {
    color: rgba(255,255,255,0.48);
    background: rgba(255,255,255,0.04);
