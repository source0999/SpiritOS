<file path="src/app/globals.css">
/* ── Spirit OS globals — minimal @theme + Tailwind v4 import ─────────────────
 * > Turbopack/PostCSS was eating glass on this tree; keep @theme flat, fewer @apply.
 * > Accents + ThemeEngine: _blueprints/design_system.md
 */

@import "tailwindcss" source(none);
@source "./";
@source "../components";
@source "../lib";
@source "../theme";

@theme {
  --color-ink: #0a0a0a;
  --color-void: #090a0f;
  --color-glass: #1a1a1e;
  --color-chalk: #f4f4f5;
  --color-cyan: #22d3ee;
  --color-violet: #a855f7;
  --color-rose: #f43f5e;
  --color-emerald: #10b981;
  --color-amber: #f59e0b;
  --font-sans: var(--font-inter), ui-sans-serif, system-ui, sans-serif;
  --font-mono: var(--font-jetbrains-mono), ui-monospace, monospace;
  --text-display: clamp(2.5rem, 8vw, 6rem);
  --text-h1: clamp(2rem, 5vw, 3.5rem);
  --text-h2: clamp(1.5rem, 4vw, 2.5rem);
  --text-body: clamp(1rem, 2.5vw, 1.125rem);
  --leading-reader: 1.8;
  --spacing-section-y: clamp(4rem, 12vw, 6rem);
  --radius-card: 1.5rem;
}

:root,
html[data-theme="spirit-slate"] {
