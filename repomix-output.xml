    .notice { display: flex; gap: 9px; align-items: flex-start; border-radius: 14px; border: 1px solid oklch(.80 .16 80 / .22); background: oklch(.80 .16 80 / .10); color: oklch(.88 .10 80); padding: 10px 12px; font-size: 11px; line-height: 1.45; }
    .terminal-lines { font-size: 11.5px; line-height: 1.72; display: flex; flex-direction: column; gap: 2px; }
    .term-line { display: grid; grid-template-columns: 72px minmax(0, 1fr); gap: 8px; }
    .cursor { animation: blink 1s steps(1) infinite; }
    @keyframes blink { 50% { opacity: 0; } }

    .command-scrim { position: fixed; inset: 0; z-index: 70; background: rgb(4 4 8 / .60); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); display: none; }
    .command-panel { position: fixed; z-index: 80; top: 10vh; left: 50%; width: min(760px, calc(100vw - 28px)); padding: 8px; transform: translate(-50%, -10px) scale(.985); opacity: 0; pointer-events: none; transition: 180ms ease; }
    .command-open .command-scrim { display: block; }
    .command-open .command-panel { opacity: 1; pointer-events: auto; transform: translate(-50%, 0) scale(1); }
    .command-inner { max-height: 72vh; display: flex; flex-direction: column; border-radius: 30px; overflow: hidden; border: 1px solid color-mix(in oklch, var(--spirit-500) 22%, var(--stroke-1)); box-shadow: var(--shadow-2), 0 0 70px color-mix(in oklch, var(--spirit-500) 30%, transparent); }
    .command-input { display: flex; align-items: center; gap: 12px; padding: 15px 18px; border-bottom: 1px solid var(--stroke-1); }
    .command-input input { flex: 1; min-width: 0; height: 32px; border: 0; outline: 0; background: transparent; color: var(--text-1); font-size: 15px; }
    .suggestions { overflow: auto; padding: 10px; }
    .suggestion { display: grid; grid-template-columns: 34px minmax(0, 1fr) auto; gap: 12px; align-items: center; width: 100%; border: 0; border-radius: 14px; padding: 10px 12px; background: transparent; text-align: left; transition: 120ms ease; }
    .suggestion:hover, .suggestion.active { background: linear-gradient(180deg, color-mix(in oklch, var(--spirit-500) 16%, transparent), rgb(255 255 255 / .025)); box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--spirit-500) 28%, transparent); }
    .suggestion .box { width: 34px; height: 34px; border-radius: 10px; border: 1px solid var(--stroke-2); background: var(--glass-2); display: grid; place-items: center; color: var(--spirit-300); }
    .command-footer { border-top: 1px solid var(--stroke-1); padding: 10px 18px; display: flex; align-items: center; justify-content: space-between; gap: 12px; background: rgb(0 0 0 / .22); flex-wrap: wrap; }
    .hidden { display: none !important; }

    .tweaks-toggle { position: fixed; right: 16px; bottom: 16px; z-index: 55; }
    .tweaks { position: fixed; right: 16px; bottom: 66px; z-index: 56; width: min(320px, calc(100vw - 24px)); display: none; padding: 16px; border-radius: 26px; border: 1px solid color-mix(in oklch, var(--spirit-500) 16%, var(--stroke-1)); box-shadow: var(--shadow-2), 0 0 50px color-mix(in oklch, var(--spirit-500) 18%, transparent); }
    @media (max-width: 880px) { .tweaks { left: 12px; right: 12px; bottom: 12px; width: auto; } .tweaks-toggle { bottom: 12px; right: 12px; } }
