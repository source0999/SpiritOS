<file path="src/styles/spirit-demo.layout.css">
/* ── Spirit Demo · Layout ────────────────────────────────────────────────────
 * > Shell, section grid, mobile dock, side rail, safe-area handling.
 * > Mobile-first. Targets iPhone 375px / Android 360px / tablet / desktop.
 * > All selectors are nested under .spirit-demo-root - no leakage.
 * ────────────────────────────────────────────────────────────────────────── */

.spirit-demo-root {
  position: relative;
  min-height: 100dvh;
  width: 100%;
  background-color: var(--demo-bg);
  color: var(--demo-text);
  overflow-x: hidden;
  /* Reserve space for mobile bottom dock (overridden on lg) */
  padding-bottom: calc(5rem + env(safe-area-inset-bottom, 0px));
  font-feature-settings: "kern" 1, "liga" 1;
}

@media (min-width: 1024px) {
  .spirit-demo-root {
    padding-bottom: env(safe-area-inset-bottom, 0px);
    /* Reserve space for the desktop side rail */
    padding-left: 4.5rem;
  }
}

/* - -  Atmospherics layer - -  */
.spirit-demo-root .demo-atmos {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: var(--demo-z-bg);
}
.spirit-demo-root .demo-atmos__aurora {
  position: absolute;
  inset: -10%;
  z-index: var(--demo-z-aurora);
  background:
    radial-gradient(
      ellipse 60% 45% at 18% 12%,
      color-mix(in oklab, var(--demo-cyan) 18%, transparent),
      transparent 60%
    ),
    radial-gradient(
      ellipse 50% 40% at 86% 30%,
      color-mix(in oklab, var(--demo-violet) 16%, transparent),
      transparent 60%
    ),
    radial-gradient(
      ellipse 70% 55% at 50% 110%,
      color-mix(in oklab, var(--demo-cyan) 12%, transparent),
      transparent 60%
    );
  filter: blur(20px) saturate(120%);
  opacity: 0.85;
}
.spirit-demo-root .demo-atmos__grid {
  position: absolute;
  inset: 0;
  z-index: var(--demo-z-grid);
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
  background-size: 56px 56px;
  mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, black 30%, transparent 80%);
  -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, black 30%, transparent 80%);
  opacity: 0.6;
}
.spirit-demo-root .demo-atmos__noise {
  position: absolute;
  inset: 0;
  z-index: var(--demo-z-noise);
  opacity: 0.04;
  mix-blend-mode: overlay;
  background-image:
    repeating-radial-gradient(
      circle at 20% 30%,
      rgba(255, 255, 255, 0.6) 0,
      rgba(255, 255, 255, 0.6) 0.5px,
      transparent 1px,
      transparent 4px
    );
}
.spirit-demo-root .demo-atmos__vignette {
  position: absolute;
  inset: 0;
  z-index: var(--demo-z-grid);
  background: radial-gradient(
    ellipse 90% 70% at 50% 50%,
    transparent 50%,
    color-mix(in oklab, var(--demo-bg-deep) 92%, black) 100%
  );
}

/* - -  Shell - -  */
.spirit-demo-root .demo-shell {
  position: relative;
  z-index: var(--demo-z-content);
  display: flex;
  flex-direction: column;
  width: 100%;
  max-width: min(1280px, 100%);
  margin: 0 auto;
  padding-inline: clamp(1rem, 4vw, 2rem);
  padding-top: calc(1rem + env(safe-area-inset-top, 0px));
}

/* - -  Section bands - -  */
.spirit-demo-root .demo-section {
  position: relative;
  padding-block: clamp(2.5rem, 7vw, 4.5rem);
  scroll-margin-top: 5rem;
}
.spirit-demo-root .demo-section + .demo-section {
  border-top: 1px solid var(--demo-border);
}

/* - -  Section header (eyebrow + title + lede) - -  */
.spirit-demo-root .demo-section__header {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  max-width: 56rem;
  margin-bottom: clamp(1.5rem, 3vw, 2.25rem);
}
.spirit-demo-root .demo-section__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
  font-size: var(--demo-text-eyebrow);
  font-weight: 600;
  letter-spacing: var(--demo-tracking-rail);
  text-transform: uppercase;
  color: color-mix(in oklab, var(--demo-accent-strong) 78%, white);
}
.spirit-demo-root .demo-section__eyebrow::before {
  content: "";
  width: 1.5rem;
  height: 1px;
  background: linear-gradient(
    90deg,
