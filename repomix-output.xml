                      {row.text}
                    </li>
                  ))}
              </ul>
            </div>
          ) : null}
        </details>
      </div>

      <details
        className="oracle-chrome-px shrink-0 border-t border-[color:var(--spirit-border)] bg-black/20 py-2"
