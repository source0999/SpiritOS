            <div className="h-2 overflow-hidden rounded-full bg-zinc-800">
              <motion.div
                className={cn(
                  "h-full rounded-full bg-gradient-to-r from-emerald-500 to-cyan-400",
                  n.load >= 70 && "from-amber-500 to-orange-400",
