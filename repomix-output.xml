  }
  .homelab-status-dot--offline {
    background: oklch(0.66 0.20 25);
    box-shadow: 0 0 8px oklch(0.66 0.20 25 / 0.7), 0 0 0 3px oklch(0.66 0.20 25 / 0.12);
    animation: none;
  }

  /* Glowing tag (SSD, HDD, labels) */
  .homelab-tag {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--spirit-accent-strong);
    padding: 3px 8px;
    border-radius: 9999px;
    border: 1px solid color-mix(in oklab, var(--spirit-accent) 28%, transparent);
    background: color-mix(in oklab, var(--spirit-accent) 12%, transparent);
    white-space: nowrap;
    animation: hl-tag-glow 2.8s ease-in-out infinite;
  }
  .homelab-tag::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(110deg, transparent 10%, rgba(255,255,255,0.24) 50%, transparent 90%);
    transform: translateX(-130%);
    animation: hl-tag-sheen 3.5s linear infinite;
  }
  .homelab-tag--ssd {
    color: oklch(0.72 0.14 230);
    border-color: oklch(0.72 0.14 230 / 0.28);
    background: oklch(0.72 0.14 230 / 0.10);
  }
  .homelab-tag--hdd {
    color: rgba(255,255,255,0.50);
    border-color: rgba(255,255,255,0.10);
    background: rgba(255,255,255,0.04);
    animation: none;
  }
  .homelab-tag--hdd::after {
