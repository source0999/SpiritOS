                initial={{ width: 0 }}
                animate={{ width: `${n.load}%` }}
                transition={{ type: "spring", stiffness: 120, damping: 20, delay: idx * 0.06 }}
              />
            </div>
          </li>
        ))}
      </ul>
    </div>
  );
}
