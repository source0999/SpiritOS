  <script>
    const $ = (sel, root = document) => root.querySelector(sel);
    const $$ = (sel, root = document) => Array.from(root.querySelectorAll(sel));

    const navItems = [
      ["⌘", "Command", "#", "01"], ["✦", "Oracle", "#oracle", "02"], ["▣", "Projects", "#projects", "03"],
      ["◫", "Storage", "#storage", "04"], ["⚡", "Energy", "#energy", "05"], ["⚗", "Quarantine", "#quarantine", "06"],
    ];
    function renderNav(target) {
      target.innerHTML = '<span class="nav-label"><span class="dot"></span>Modules</span>' + navItems.map((n, i) => `
        <a class="nav-item ${i === 0 ? 'active' : ''}" href="${n[2]}" data-nav>
          <span class="nav-icon">${n[0]}</span><span>${n[1]}</span><span class="nav-code mono">${n[3]}</span>
        </a>`).join('');
    }
    renderNav($('#desktopNav')); renderNav($('#mobileNav'));
    $$('[data-nav]').forEach(link => link.addEventListener('click', e => {
      $$('[data-nav]').forEach(x => x.classList.remove('active'));
      e.currentTarget.classList.add('active');
      document.body.classList.remove('drawer-open');
      document.body.style.position = '';
      const href = e.currentTarget.getAttribute('href');
      if (href && href !== '#') setTimeout(() => $(href)?.scrollIntoView({behavior:'smooth', block:'start'}), 0);
      e.preventDefault();
    }));

    const nodes = [
      ["spiritdesktop", "Ryzen AM5 · 12% CPU", "live"], ["spirit (Dell)", "i7-6700 · 34% CPU", "live"],
      ["Ghost Node", "Pi 3 · 22% CPU", "live"], ["Tesla P40", "Awaiting PSU upgrade", "pending"]
    ];
    $('#nodes').innerHTML = nodes.map(n => { const pending = n[2] === 'pending'; const stat = pending ? 'Standby' : 'Nominal'; return `<div class="cluster-node"><span class="state-dot ${pending ? 'pending' : ''}"></span><div class="cluster-node-copy"><strong>${n[0]}</strong><span>${n[1]}</span></div><div class="cluster-node-stat"><strong>${stat}</strong><span>${pending ? 'queued' : 'live'}</span></div></div>`; }).join('');

    $('#wave').innerHTML = Array.from({length: 30}, (_, i) => `<span class="bar" style="--i:${i};--h:${5 + ((i * 47 + 9) % 18)}"></span>`).join('');

    const briefings = [
      ["Local LLM", "Llama 3.3 Q4_K_M quant benchmarks on consumer DDR5 - context window throughput.", "06:02", "arxiv"],
      ["Homelab", "PCIe x1 riser bottleneck: TTFT degradation on 24GB VRAM models vs x16 ribbon.", "06:04", "level1tech"],
      ["Privacy", "CCPA Q3 enforcement: brokers ignoring opt-outs face record seven-figure penalties.", "06:06", "eff"],
      ["Energy", "SoCal ToU shift: super off-peak window narrows to 11 PM–5 AM next billing cycle.", "06:08", "sce"]
    ];
