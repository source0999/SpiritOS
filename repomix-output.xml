@import "tailwindcss" source(none);
@source "./";
@source "../components";
@source "../lib";
@source "../theme";

@theme {
  --color-ink: #0a0a0a;
  --color-void: #090a0f;
  --color-glass: #1a1a1e;
  --color-chalk: #f4f4f5;
  --color-cyan: #22d3ee;
  --color-violet: #a855f7;
  --color-rose: #f43f5e;
  --color-emerald: #10b981;
  --color-amber: #f59e0b;
  --font-sans: var(--font-inter), ui-sans-serif, system-ui, sans-serif;
  --font-mono: var(--font-jetbrains-mono), ui-monospace, monospace;
  --text-display: clamp(2.5rem, 8vw, 6rem);
  --text-h1: clamp(2rem, 5vw, 3.5rem);
  --text-h2: clamp(1.5rem, 4vw, 2.5rem);
  --text-body: clamp(1rem, 2.5vw, 1.125rem);
  --leading-reader: 1.8;
  --spacing-section-y: clamp(4rem, 12vw, 6rem);
  --radius-card: 1.5rem;
}

/* Default palette = Frozen Water; useSpiritTheme mirrors stored choice onto <html> */
:root {
  --spirit-bg: #161413;
  --spirit-bg-soft: #1e1c1a;
  --spirit-panel: #242120;
  --spirit-panel-strong: #2e2b29;
  --spirit-accent: #8fb8de;
  --spirit-accent-strong: #cdf7f6;
  --spirit-glow: rgba(143, 184, 222, 0.28);
  --spirit-border: rgba(205, 247, 246, 0.11);
  --spirit-secondary-mix: #9a94bc;
}

@utility glass {
  background: rgba(255, 255, 255, 0.02);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.06);
}

@utility scrollbar-hide {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

@utility shadow-quarantine-inset {
  box-shadow: inset 0 0 120px color-mix(in oklab, var(--color-rose) 14%, transparent);
}

@layer utilities {
