          sessionId: "d22b1b",
          hypothesisId: "B",
          location: "SpiritChat.tsx:scrollTouchTop",
          message: "touchmove with message scroller near top (PTR / rubber-band)",
          data: {
            scrollTop: Math.round(el.scrollTop),
            scrollHeight: Math.round(el.scrollHeight),
            clientHeight: Math.round(el.clientHeight),
            msgCount: displayMessages.length,
