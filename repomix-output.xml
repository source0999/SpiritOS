<file path="frontend/app/globals.css">
@import "tailwindcss";

@custom-variant dark (&:where(.dark, .dark *));

/* Spirit OS shell is always dark (`layout.tsx` → <html className="dark">).
   The default Next.js template used light :root tokens. Combined with
   `body { background: var(--background) }` that produced a *white* page on
   light OS settings, while AppShell applies `text-zinc-100` — essentially
   white-on-white, which reads as a blank screen. */
:root {
  --background: #09090b;
  --foreground: #fafafa;
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --font-sans: var(--font-geist-sans);
  --font-mono: var(--font-geist-mono);
}

body {
  background: var(--background);
  color: var(--foreground);
  font-family: var(--font-geist-sans), ui-sans-serif, system-ui, sans-serif;
}

/* ─── Oracle Orb · Navi CSS Animations ─────────────────────────────────────
   All transforms use translate3d / rotate3d so iOS WebKit promotes each
   element to its own GPU compositing layer. No backdrop-filter anywhere.
   ──────────────────────────────────────────────────────────────────────── */

/* Fairy flight path — smooth elliptical orbit around the centre point.
   rotate() adds a banking tilt so Navi leans into turns like a real fairy. */
@keyframes navi-fly {
  0%   { transform: translate3d( 50px,  0px, 0) rotate( 5deg);  }
  25%  { transform: translate3d(  0px,-28px, 0) rotate(-12deg); }
  50%  { transform: translate3d(-50px,  0px, 0) rotate(-5deg);  }
  75%  { transform: translate3d(  0px, 28px, 0) rotate( 12deg); }
  100% { transform: translate3d( 50px,  0px, 0) rotate( 5deg);  }
}

/* Nucleus glow pulse — animates opacity + scale3d on a radial-gradient span.
   WebKit on iOS repaints box-shadow on every frame (CPU operation).
   By keeping the box-shadow static and animating only opacity/scale3d on a
   separate sibling span, the pulse runs entirely on the GPU compositor. */
@keyframes navi-glow-opacity {
  0%, 100% { opacity: 0.45; transform: scale3d(1.00, 1.00, 1); }
  50%       { opacity: 1.00; transform: scale3d(1.20, 1.20, 1); }
}

/* Orbit rings — translate3d(0,0,0) anchors the element on the GPU layer
   before the rotation begins, preventing compositor promotion jank on iOS */
@keyframes navi-orbit         { to { transform: translate3d(0,0,0) rotate( 360deg); } }
@keyframes navi-orbit-reverse { to { transform: translate3d(0,0,0) rotate(-360deg); } }

/* Aura pulse — scale3d forces GPU compositing layer (iOS safe) */
@keyframes navi-pulse {
  0%, 100% { opacity: 0.35; transform: scale3d(1.00, 1.00, 1); }
  50%       { opacity: 0.80; transform: scale3d(1.12, 1.12, 1); }
}

/* Wing wisps — scale3d(x,1,1) instead of scaleX(x): explicit 3D keeps
   the element on the GPU compositor throughout the animation */
@keyframes navi-wing-l {
  0%, 100% { transform: translate3d(-20px, -5px,  0) rotate(-38deg) scale3d(1.00, 1, 1); opacity: 0.50; }
  50%       { transform: translate3d(-17px, -12px, 0) rotate(-46deg) scale3d(0.70, 1, 1); opacity: 0.88; }
}
@keyframes navi-wing-r {
  0%, 100% { transform: translate3d( 20px, -5px,  0) rotate( 38deg) scale3d(1.00, 1, 1); opacity: 0.50; }
  50%       { transform: translate3d( 17px, -12px, 0) rotate( 46deg) scale3d(0.70, 1, 1); opacity: 0.88; }
}

/* Audio bar — scale3d(1,y,1) is fully GPU-composited (iOS safe).
   transform-origin: bottom is set via Tailwind's origin-bottom class. */
@keyframes navi-bar {
  from { transform: scale3d(1, 0.15, 1); }
  to   { transform: scale3d(1, 1.00, 1); }
}

/* ─── Named animation utility classes ───────────────────────────────────────
   Applied directly in JSX as className values so Tailwind v4's arbitrary
   value scanner is bypassed entirely. Pure CSS — reliable on all engines.
   ──────────────────────────────────────────────────────────────────────── */

/* Ambient glow at the centre — slow pulse */
.navi-aura {
  animation: navi-pulse 4.4s ease-in-out infinite;
}

/* Mid glow halo — medium pulse with delay */
.navi-halo {
  animation: navi-pulse 3s ease-in-out 0.7s infinite;
}

/* Wing wisp — left (child of the flying button) */
.navi-wing-l {
  animation: navi-wing-l 2.9s ease-in-out infinite;
}

/* Wing wisp — right (offset start so wings don't sync perfectly) */
.navi-wing-r {
  animation: navi-wing-r 2.9s ease-in-out 0.5s infinite;
}

/* The main entity follows the elliptical flight path */
.navi-float {
  animation: navi-fly 5s ease-in-out infinite;
}

/* ── Particle trail ──────────────────────────────────────────────────────────
   Each particle follows the EXACT same flight path as the entity but with a
   negative animation-delay, placing it at where the entity WAS n seconds ago.
   Decreasing opacity + size creates a fading comet tail behind Navi.
   ────────────────────────────────────────────────────────────────────────── */
.navi-p1 { animation: navi-fly 5s ease-in-out -0.40s infinite; }
.navi-p2 { animation: navi-fly 5s ease-in-out -0.80s infinite; }
.navi-p3 { animation: navi-fly 5s ease-in-out -1.20s infinite; }
.navi-p4 { animation: navi-fly 5s ease-in-out -1.60s infinite; }
.navi-p5 { animation: navi-fly 5s ease-in-out -2.00s infinite; }

/* Immediate halo ring around the nucleus button */
.navi-halo-btn {
  animation: navi-pulse 2.3s ease-in-out infinite;
}

/* ─── Oracle page · XL Navi (h-72 w-72 container, h-20 w-20 entity) ─────────
   Same anatomy as the bento orb but ~1.7× larger flight ellipse + entity.
   ──────────────────────────────────────────────────────────────────────── */

@keyframes navi-fly-xl {
  0%   { transform: translate3d( 90px,  0px, 0) rotate( 5deg);  }
  25%  { transform: translate3d(  0px,-50px, 0) rotate(-12deg); }
  50%  { transform: translate3d(-90px,  0px, 0) rotate(-5deg);  }
  75%  { transform: translate3d(  0px, 50px, 0) rotate( 12deg); }
  100% { transform: translate3d( 90px,  0px, 0) rotate( 5deg);  }
}

@keyframes navi-wing-l-xl {
  0%, 100% { transform: translate3d(-34px, -8px, 0) rotate(-38deg) scale3d(1.00, 1, 1); opacity: 0.55; }
  50%       { transform: translate3d(-30px,-20px, 0) rotate(-46deg) scale3d(0.70, 1, 1); opacity: 0.90; }
}
@keyframes navi-wing-r-xl {
  0%, 100% { transform: translate3d( 34px, -8px, 0) rotate( 38deg) scale3d(1.00, 1, 1); opacity: 0.55; }
  50%       { transform: translate3d( 30px,-20px, 0) rotate( 46deg) scale3d(0.70, 1, 1); opacity: 0.90; }
}

.navi-float-xl  { animation: navi-fly-xl    5s  ease-in-out        infinite; }
.navi-wing-l-xl { animation: navi-wing-l-xl 2.9s ease-in-out        infinite; }
.navi-wing-r-xl { animation: navi-wing-r-xl 2.9s ease-in-out 0.5s   infinite; }
.navi-p1-xl     { animation: navi-fly-xl    5s  ease-in-out -0.40s  infinite; }
.navi-p2-xl     { animation: navi-fly-xl    5s  ease-in-out -0.80s  infinite; }
.navi-p3-xl     { animation: navi-fly-xl    5s  ease-in-out -1.20s  infinite; }
.navi-p4-xl     { animation: navi-fly-xl    5s  ease-in-out -1.60s  infinite; }
.navi-p5-xl     { animation: navi-fly-xl    5s  ease-in-out -2.00s  infinite; }

/* XL nucleus — same pattern: static box-shadow, no animation */
.navi-core-xl {
  box-shadow:
    0 0 16px  8px rgba(139, 92, 246, 0.70),
    0 0 40px 20px rgba(139, 92, 246, 0.38),
    0 0  4px  2px rgba(255, 255, 255, 0.95);
}

/* Bright nucleus — static box-shadow only; the pulsing glow lives on the
   sibling .navi-glow-pulse span so box-shadow is NEVER animated (iOS GPU safe) */
.navi-core {
  box-shadow:
    0 0  8px  4px rgba(139, 92, 246, 0.65),
    0 0 22px 10px rgba(139, 92, 246, 0.28),
    0 0  2px  1px rgba(255, 255, 255, 0.90);
}

/* Glow pulse aura — opacity + scale3d on a radial-gradient span.
   Renders below .navi-core in the stacking order (earlier in the DOM). */
.navi-glow-pulse {
  animation: navi-glow-opacity 2.6s ease-in-out infinite;
}

/* ── Terminal block cursor ──────────────────────────────────────────────────
   step-start gives the authentic hard on/off blink — no fade.
   Applied to the █ span that appears when the terminal input is empty.     */
@keyframes term-blink {
  0%, 49.9% { opacity: 1; }
  50%, 100%  { opacity: 0; }
}
.term-cursor {
  animation: term-blink 1.1s step-start infinite;
}

/* ── Matrix scrollbars ────────────────────────────────────────────────────────
   Thin emerald-tinted thumbs on a transparent track.
   Webkit (Chrome, Safari, Edge) + Firefox covered.
   4px width keeps them unobtrusive while the green tint reads as "terminal".
   Hover brightens the thumb so it's still discoverable.
   ──────────────────────────────────────────────────────────────────────────── */
::-webkit-scrollbar {
  width:  4px;
  height: 4px;
}
::-webkit-scrollbar-track {
  background: transparent;
}
::-webkit-scrollbar-thumb {
  background:    rgba(16, 185, 129, 0.22);
  border-radius: 9999px;
}
::-webkit-scrollbar-thumb:hover {
  background: rgba(16, 185, 129, 0.48);
}
::-webkit-scrollbar-corner {
  background: transparent;
}

/* Firefox */
* {
  scrollbar-width: thin;
  scrollbar-color: rgba(16, 185, 129, 0.22) transparent;
}

/* ─── YTM Intelligence Hub ───────────────────────────────────────────────────
   ytm-art-entrance: album art translate3d + scale3d entrance on track change.
   scrubber-pulse:   Maloja badge opacity breathe during active playback.
   Both run entirely on the GPU compositor — no layout repaints on iOS.
   ──────────────────────────────────────────────────────────────────────────── */

@keyframes ytm-art-entrance {
  from { opacity: 0; transform: translate3d(0, 6px, 0) scale3d(0.96, 0.96, 1); }
  to   { opacity: 1; transform: translate3d(0,  0px, 0) scale3d(1.00, 1.00, 1); }
}

@keyframes scrubber-pulse {
  0%, 100% { opacity: 0.80; }
  50%       { opacity: 1.00; }
}

.ytm-art-entrance {
  animation: ytm-art-entrance 320ms cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

.scrubber-pulse {
  animation: scrubber-pulse 2.4s ease-in-out infinite;
}

/* ─── YTM On Repeat row hover ────────────────────────────────────────────────
   scale3d keeps hover strictly on the GPU compositor.
   The Z component of 1 explicitly promotes the element to a GPU compositing
   layer on iOS WebKit. No layout recalculation occurs during hover transitions.
   ──────────────────────────────────────────────────────────────────────────── */
.on-repeat-row {
  border-radius: 0.625rem;
  transition: transform 140ms ease-out, background 140ms ease-out;
}
.on-repeat-row:hover {
  background: rgba(255, 255, 255, 0.04);
  transform: scale3d(1.008, 1.008, 1);
}
