// ── verified-http-url - shared digest / policy / header URL gate ─────────────────
// > Client-safe: `research-source-enforcement` is imported by SpiritChat; do not
//   depend on `server-only` OpenAI modules here.

/**
 * Bare host / protocol-relative → https so OpenAI payload quirks still produce
 * one canonical string for digest lines and `x-spirit-web-sources`.
 */
export function normalizeToHttpUrl(raw: string | undefined): string | undefined {
  let t = (raw ?? "").trim();
  // OpenAI / markdown sometimes wraps links - strip before host detection.
  t = t.replace(/^<+/, "").replace(/>+$/, "").trim();
  if (!t) return undefined;
  if (/^(javascript|data|mailto|vbscript):/i.test(t)) return undefined;
  if (/^https?:\/\//i.test(t)) return t;
  if (t.startsWith("//")) {
    const host = t.slice(2).replace(/^\/+/, "");
    return host ? `https://${host}` : undefined;
  }
  if (/[\s<>"]/.test(t)) return undefined;
  if (!/^[a-zA-Z0-9][a-zA-Z0-9.-]*\.[a-zA-Z]{2,}/.test(t)) return undefined;
  return `https://${t}`;
}

/**
 * After normalization, only true http(s) origins count as “verified” everywhere:
 * digest, Teacher budget, policy `searchUsed`, telemetry headers.
 */
export function resolveVerifiedHttpUrl(raw: string | undefined): string | undefined {
  const n = normalizeToHttpUrl(raw);
  if (!n) return undefined;
  return /^https?:\/\//i.test(n) ? n : undefined;
}

/** `normalizeToHttpUrl` then strict `^https?:` - post-normalize bare hosts count as verified. */
export function isVerifiedHttpUrl(url: string | undefined): boolean {
  return Boolean(resolveVerifiedHttpUrl(url));
}
</file>

<file path="src/styles/spirit-demo.animations.css">
/* ── Spirit Demo · Animations ────────────────────────────────────────────────
 * > Keyframes + motion utility classes + reduced-motion overrides.
 * > All keyframe identifiers are prefixed `demo*` so they cannot collide with
 *   any keyframes defined in the host app.
 * > Respects `prefers-reduced-motion: reduce` - looping motion is disabled,
 *   static gradients and layout remain.
 * ────────────────────────────────────────────────────────────────────────── */

/* ─────────── Keyframes ─────────── */
@keyframes demoOrbBreathe {
  0%, 100% {
    transform: scale(1);
    box-shadow:
      0 0 36px -2px color-mix(in oklab, var(--demo-cyan, #22d3ee) 50%, transparent),
      0 0 68px -8px color-mix(in oklab, var(--demo-violet, #a855f7) 45%, transparent),
      inset 0 0 28px -6px rgba(255, 255, 255, 0.32);
  }
  50% {
    transform: scale(1.04);
    box-shadow:
      0 0 48px 0 color-mix(in oklab, var(--demo-cyan, #22d3ee) 60%, transparent),
      0 0 88px -4px color-mix(in oklab, var(--demo-violet, #a855f7) 55%, transparent),
      inset 0 0 32px -4px rgba(255, 255, 255, 0.4);
  }
}

@keyframes demoOrbHalo {
  0%, 100% { opacity: 0.7; transform: scale(1); }
  50%      { opacity: 1;   transform: scale(1.06); }
}

@keyframes demoOrbPulse {
  0%, 100% { transform: scale(1);    opacity: 0.4; }
  50%      { transform: scale(1.08); opacity: 0.85; }
}

@keyframes demoWave {
  0%, 100% { height: 18%; }
  20%      { height: 65%; }
  40%      { height: 30%; }
  60%      { height: 90%; }
  80%      { height: 45%; }
}

@keyframes demoPulseDot {
  0%   { transform: scale(0.9);  opacity: 0.9; }
  80%  { transform: scale(2.2);  opacity: 0; }
  100% { transform: scale(2.4);  opacity: 0; }
}

@keyframes demoShimmer {
  0%      { opacity: 0;    transform: translateX(-30%); }
  10%     { opacity: 0.9; }
  50%     { opacity: 0.9;  transform: translateX(0); }
  90%     { opacity: 0.9; }
  100%    { opacity: 0;    transform: translateX(30%); }
}

@keyframes demoGradientPan {
  0%   { background-position:   0% 50%; }
  100% { background-position: 200% 50%; }
}

@keyframes demoFadeUp {
  0%   { opacity: 0; transform: translateY(8px); }
  100% { opacity: 1; transform: translateY(0); }
}

@keyframes demoBlinkCaret {
  0%, 60%   { opacity: 1; }
  61%, 100% { opacity: 0; }
}

@keyframes demoScrollUp {
  0%   { transform: translateY(0); }
  100% { transform: translateY(-50%); }
}

/* ─────────── Motion utilities ─────────── */
.spirit-demo-root .demo-motion-fade-up {
  animation: demoFadeUp var(--demo-dur-mid) var(--demo-ease-out) both;
}
.spirit-demo-root .demo-motion-fade-up--delay-1 { animation-delay: 80ms; }
.spirit-demo-root .demo-motion-fade-up--delay-2 { animation-delay: 160ms; }
.spirit-demo-root .demo-motion-fade-up--delay-3 { animation-delay: 240ms; }
.spirit-demo-root .demo-motion-fade-up--delay-4 { animation-delay: 320ms; }
.spirit-demo-root .demo-motion-fade-up--delay-5 { animation-delay: 400ms; }

.spirit-demo-root .demo-motion-caret {
  animation: demoBlinkCaret 1.1s steps(1) infinite;
}

.spirit-demo-root .demo-motion-marquee {
  display: flex;
  flex-direction: column;
  animation: demoScrollUp 28s linear infinite;
}

/* ─────────── Reduced motion overrides ─────────── */
@media (prefers-reduced-motion: reduce) {
  .spirit-demo-root *,
  .spirit-demo-root *::before,
  .spirit-demo-root *::after {
    animation-duration: 0.001ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.001ms !important;
    scroll-behavior: auto !important;
  }
  /* Keep the orb visually stable but not animated */
  .spirit-demo-root .demo-orb__core {
    transform: none !important;
  }
  .spirit-demo-root .demo-orb__halo,
  .spirit-demo-root .demo-orb__ring {
    opacity: 0.6 !important;
    transform: none !important;
  }
  /* Keep waveform legible (static height) */
  .spirit-demo-root .demo-wave__bar {
    height: 38% !important;
  }
  /* Keep gradient text visible without panning */
  .spirit-demo-root .demo-hero__title em {
    background-position: 0% 50% !important;
    animation: none !important;
  }
  /* Keep shimmer line invisible (no looping sweep) */
  .spirit-demo-root .demo-shimmer {
    opacity: 0 !important;
    animation: none !important;
  }
  /* Pulse dot rings hidden - keep only the static dot */
  .spirit-demo-root .demo-pulse-dot::after {
    display: none !important;
  }
}

/* Focus ring (accessibility) - always present, doesn’t care about motion */
.spirit-demo-root :where(a, button, [role="button"]):focus-visible {
  outline: 2px solid color-mix(in oklab, var(--demo-cyan) 80%, transparent);
  outline-offset: 2px;
  border-radius: inherit;
}
</file>

<file path="src/styles/spirit-demo.components.css">
/* ── Spirit Demo · Components ────────────────────────────────────────────────
 * > Cards, buttons, badges, panels, chat bubbles, status rows, profile chips.
 * > Fully scoped under .spirit-demo-root.
 * ────────────────────────────────────────────────────────────────────────── */

/* ─────────── Cards ─────────── */
.spirit-demo-root .demo-card {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 0.875rem;
  padding: clamp(1rem, 2.4vw, 1.4rem);
  border-radius: var(--demo-radius-lg);
  background: var(--demo-glass);
  border: 1px solid var(--demo-border);
  box-shadow: var(--demo-inset-shine);
  backdrop-filter: blur(var(--demo-blur-md));
  -webkit-backdrop-filter: blur(var(--demo-blur-md));
  transition:
    transform var(--demo-dur-mid) var(--demo-ease-out),
    border-color var(--demo-dur-mid) var(--demo-ease-out),
    box-shadow var(--demo-dur-mid) var(--demo-ease-out);
}
@media (min-width: 1024px) and (hover: hover) {
  .spirit-demo-root .demo-card:hover {
    transform: translateY(-2px);
    border-color: var(--demo-border-strong);
    box-shadow:
      var(--demo-glow-soft),
      var(--demo-inset-shine-strong);
  }
}
.spirit-demo-root .demo-card--feature {
  background: linear-gradient(
    150deg,
    color-mix(in oklab, var(--demo-cyan) 7%, transparent),
    color-mix(in oklab, var(--demo-violet) 4%, transparent) 60%,
    transparent
  );
  border-color: color-mix(in oklab, var(--demo-cyan) 26%, transparent);
  box-shadow: var(--demo-glow-soft), var(--demo-inset-shine-strong);
}
.spirit-demo-root .demo-card--quarantine {
  border-color: color-mix(in oklab, var(--demo-rose) 32%, transparent);
  background: linear-gradient(
    160deg,
    color-mix(in oklab, var(--demo-rose) 8%, transparent),
    color-mix(in oklab, var(--demo-rose) 1.5%, transparent) 70%
  );
  box-shadow: var(--demo-glow-rose), var(--demo-inset-shine);
}
.spirit-demo-root .demo-card--oracle {
  border-color: color-mix(in oklab, var(--demo-violet) 30%, transparent);
  background: linear-gradient(
    160deg,
    color-mix(in oklab, var(--demo-violet) 8%, transparent),
    color-mix(in oklab, var(--demo-violet) 1.5%, transparent) 70%
  );
  box-shadow: var(--demo-glow-violet), var(--demo-inset-shine);
}

.spirit-demo-root .demo-card__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
  font-size: var(--demo-text-eyebrow);
  font-weight: 600;
  letter-spacing: var(--demo-tracking-rail);
  text-transform: uppercase;
  color: color-mix(in oklab, var(--demo-accent-strong) 80%, white);
}
.spirit-demo-root .demo-card--quarantine .demo-card__eyebrow {
  color: color-mix(in oklab, var(--demo-rose-strong) 90%, white);
}
.spirit-demo-root .demo-card--oracle .demo-card__eyebrow {
  color: color-mix(in oklab, var(--demo-violet-strong) 90%, white);
}
.spirit-demo-root .demo-card__title {
  font-size: var(--demo-text-lead);
  font-weight: 600;
  line-height: 1.2;
  letter-spacing: -0.01em;
  color: var(--demo-text);
}
.spirit-demo-root .demo-card__body {
  font-size: var(--demo-text-caption);
  line-height: 1.55;
  color: var(--demo-text-muted);
}
.spirit-demo-root .demo-card__footer {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.5rem;
  margin-top: auto;
  padding-top: 0.5rem;
}

/* ─────────── Buttons ─────────── */
.spirit-demo-root .demo-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  min-height: 44px;
  min-width: 44px;
  padding: 0.55rem 1.05rem;
  border-radius: var(--demo-radius-pill);
  border: 1px solid var(--demo-border);
  background: var(--demo-glass-strong);
  color: var(--demo-text);
  font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
  font-size: var(--demo-text-caption);
  font-weight: 600;
  letter-spacing: 0.02em;
  text-decoration: none;
  cursor: pointer;
  transition:
    transform var(--demo-dur-fast) var(--demo-ease-out),
    background var(--demo-dur-fast) var(--demo-ease-out),
    border-color var(--demo-dur-fast) var(--demo-ease-out);
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
}
.spirit-demo-root .demo-btn:hover {
  border-color: var(--demo-border-strong);
  background: color-mix(in oklab, var(--demo-glass-strong) 100%, white 4%);
}
.spirit-demo-root .demo-btn:active { transform: scale(0.98); }
.spirit-demo-root .demo-btn--primary {
  background: color-mix(in oklab, var(--demo-cyan) 14%, transparent);
  border-color: color-mix(in oklab, var(--demo-cyan) 42%, transparent);
  color: var(--demo-cyan-strong);
  box-shadow: var(--demo-glow-soft);
}
.spirit-demo-root .demo-btn--primary:hover {
  background: color-mix(in oklab, var(--demo-cyan) 22%, transparent);
  border-color: color-mix(in oklab, var(--demo-cyan) 60%, transparent);
}
.spirit-demo-root .demo-btn--violet {
  background: color-mix(in oklab, var(--demo-violet) 14%, transparent);
  border-color: color-mix(in oklab, var(--demo-violet) 42%, transparent);
  color: var(--demo-violet-strong);
}
.spirit-demo-root .demo-btn--violet:hover {
  background: color-mix(in oklab, var(--demo-violet) 22%, transparent);
}
.spirit-demo-root .demo-btn--rose {
  background: color-mix(in oklab, var(--demo-rose) 12%, transparent);
  border-color: color-mix(in oklab, var(--demo-rose) 38%, transparent);
  color: var(--demo-rose-strong);
}
.spirit-demo-root .demo-btn--rose:hover {
  background: color-mix(in oklab, var(--demo-rose) 20%, transparent);
}
.spirit-demo-root .demo-btn--ghost {
  background: transparent;
  border-color: var(--demo-border);
  color: var(--demo-text-muted);
}
.spirit-demo-root .demo-btn--ghost:hover {
  color: var(--demo-text);
  border-color: var(--demo-border-strong);
}
.spirit-demo-root .demo-btn--sm {
  min-height: 36px;
  padding: 0.35rem 0.75rem;
  font-size: var(--demo-text-eyebrow);
  letter-spacing: var(--demo-tracking-rail);
  text-transform: uppercase;
}
.spirit-demo-root .demo-btn[aria-disabled="true"],
.spirit-demo-root .demo-btn:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

/* ─────────── Badges & chips ─────────── */
.spirit-demo-root .demo-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.25rem 0.6rem;
  border-radius: var(--demo-radius-pill);
  font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
  font-size: var(--demo-text-eyebrow);
  font-weight: 600;
  letter-spacing: var(--demo-tracking-rail);
  text-transform: uppercase;
  border: 1px solid var(--demo-border);
  color: var(--demo-text-muted);
  background: var(--demo-glass-soft);
  white-space: nowrap;
}
.spirit-demo-root .demo-badge--cyan {
  border-color: color-mix(in oklab, var(--demo-cyan) 36%, transparent);
  background: color-mix(in oklab, var(--demo-cyan) 10%, transparent);
  color: var(--demo-cyan-strong);
}
.spirit-demo-root .demo-badge--violet {
  border-color: color-mix(in oklab, var(--demo-violet) 36%, transparent);
  background: color-mix(in oklab, var(--demo-violet) 10%, transparent);
  color: var(--demo-violet-strong);
}
.spirit-demo-root .demo-badge--rose {
  border-color: color-mix(in oklab, var(--demo-rose) 36%, transparent);
  background: color-mix(in oklab, var(--demo-rose) 10%, transparent);
  color: var(--demo-rose-strong);
}
.spirit-demo-root .demo-badge--emerald {
  border-color: color-mix(in oklab, var(--demo-emerald) 36%, transparent);
  background: color-mix(in oklab, var(--demo-emerald) 10%, transparent);
  color: var(--demo-emerald-strong);
}
.spirit-demo-root .demo-badge--warn {
  border-color: color-mix(in oklab, var(--demo-warn) 36%, transparent);
  background: color-mix(in oklab, var(--demo-warn) 10%, transparent);
  color: var(--demo-amber-strong);
}

/* ─────────── Section nav (top tabs / dock buttons) ─────────── */
.spirit-demo-root .demo-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 1 1 auto;
  min-height: 44px;
  padding: 0.4rem 0.65rem;
  border: 0;
  background: transparent;
  color: var(--demo-text-faint);
  font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
  font-size: var(--demo-text-eyebrow);
  font-weight: 600;
  letter-spacing: var(--demo-tracking-rail);
  text-transform: uppercase;
  text-decoration: none;
  border-radius: var(--demo-radius-pill);
  cursor: pointer;
  transition:
    color var(--demo-dur-fast) var(--demo-ease-out),
    background var(--demo-dur-fast) var(--demo-ease-out);
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
}
.spirit-demo-root .demo-tab:hover { color: var(--demo-text); }
.spirit-demo-root .demo-tab[aria-current="true"],
.spirit-demo-root .demo-tab--active {
  color: var(--demo-cyan-strong);
  background: color-mix(in oklab, var(--demo-cyan) 14%, transparent);
  box-shadow: var(--demo-glow-soft);
}
.spirit-demo-root .demo-tab__icon {
  display: inline-grid;
  place-items: center;
  width: 1rem;
  height: 1rem;
  flex-shrink: 0;
}
.spirit-demo-root .demo-tab__label {
  display: none;
}
@media (min-width: 480px) {
  .spirit-demo-root .demo-tab__label {
    display: inline;
  }
}

/* ─────────── Side rail buttons ─────────── */
.spirit-demo-root .demo-rail-btn {
  display: grid;
  place-items: center;
  width: 2.6rem;
  height: 2.6rem;
  border: 1px solid transparent;
  background: transparent;
  color: var(--demo-text-faint);
  border-radius: var(--demo-radius-md);
  cursor: pointer;
  transition:
    color var(--demo-dur-fast) var(--demo-ease-out),
    background var(--demo-dur-fast) var(--demo-ease-out),
    border-color var(--demo-dur-fast) var(--demo-ease-out);
}
.spirit-demo-root .demo-rail-btn:hover {
  color: var(--demo-text);
  background: var(--demo-glass);
  border-color: var(--demo-border);
}
.spirit-demo-root .demo-rail-btn[aria-current="true"] {
  color: var(--demo-cyan-strong);
  background: color-mix(in oklab, var(--demo-cyan) 12%, transparent);
  border-color: color-mix(in oklab, var(--demo-cyan) 32%, transparent);
  box-shadow: var(--demo-glow-soft);
}

/* ─────────── Hero panel ─────────── */
.spirit-demo-root .demo-hero {
  position: relative;
  overflow: hidden;
  border-radius: var(--demo-radius-xl);
  padding: clamp(1.25rem, 4vw, 2rem);
  min-height: 18rem;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 1.25rem;
  background:
    radial-gradient(
      ellipse 70% 90% at 100% 0%,
      color-mix(in oklab, var(--demo-violet) 14%, transparent),
      transparent 65%
    ),
    radial-gradient(
      ellipse 80% 100% at 0% 100%,
      color-mix(in oklab, var(--demo-cyan) 12%, transparent),
      transparent 60%
    ),
    var(--demo-glass-strong);
  border: 1px solid color-mix(in oklab, var(--demo-cyan) 22%, transparent);
  box-shadow:
    var(--demo-glow-cyan),
    var(--demo-inset-shine-strong);
  backdrop-filter: blur(var(--demo-blur-md));
  -webkit-backdrop-filter: blur(var(--demo-blur-md));
}
.spirit-demo-root .demo-hero__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
}
.spirit-demo-root .demo-hero__title {
  font-size: var(--demo-text-h1);
  font-weight: 600;
  letter-spacing: -0.02em;
  line-height: 1;
  color: var(--demo-text);
  margin-block: 0.25rem 0.75rem;
}
.spirit-demo-root .demo-hero__title em {
  font-style: normal;
  background: linear-gradient(
    100deg,
    var(--demo-cyan-strong),
    var(--demo-violet-strong) 60%,
    var(--demo-cyan-strong)
  );
  background-size: 200% 100%;
  -webkit-background-clip: text;
          background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: demoGradientPan 12s linear infinite;
}
.spirit-demo-root .demo-hero__sub {
  max-width: 38rem;
  font-size: var(--demo-text-body);
  line-height: 1.55;
  color: var(--demo-text-muted);
}
.spirit-demo-root .demo-hero__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

/* ─────────── Status row (telemetry stripe) ─────────── */
.spirit-demo-root .demo-status-row {
  display: grid;
  grid-template-columns: minmax(0, 5rem) minmax(0, 1fr) minmax(0, auto);
  align-items: center;
  gap: 0.75rem;
  padding: 0.55rem 0.75rem;
