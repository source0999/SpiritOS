    globalThis.fetch = mockFetch;

    await synthesizeWithElevenLabs({ text: "yo", voiceId: "customVid" });

    const [url] = mockFetch.mock.calls[0] as [string, RequestInit];
    expect(url).toContain("/text-to-speech/customVid");
