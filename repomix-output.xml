    input[type="range"] { width: 100%; accent-color: var(--spirit-500); }
    select { width: 100%; background: rgb(255 255 255 / .06); border: 1px solid var(--stroke-2); color: var(--text-1); border-radius: 10px; padding: 8px 10px; }
    .switch-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-top: 10px; }
    .switch { width: 42px; height: 24px; border-radius: 999px; border: 1px solid var(--stroke-2); background: rgb(255 255 255 / .08); padding: 2px; }
    .switch::before { content: ""; display: block; width: 18px; height: 18px; border-radius: 50%; background: var(--text-2); transition: 160ms ease; }
    .switch[aria-checked="true"] { background: color-mix(in oklch, var(--spirit-500) 28%, transparent); }
