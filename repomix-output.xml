export function ThemeStrip() {
  const { theme, setTheme } = useSpiritTheme();

  return (
    <div
      aria-label="Theme palette"
      className="glass flex shrink-0 flex-wrap gap-px rounded-lg p-[3px] sm:rounded-lg"
    >
