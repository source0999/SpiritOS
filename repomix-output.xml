<file path="backend/docker-compose.yml">
# ŌöĆŌöĆŌöĆ Spirit OS ┬Ę Backend Services ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
#
# NVIDIA CUDA stack for local AI (Oracle voice pipeline + Spirit chat fallback):
#   ollama      ŌåÆ LLM inference          ŌåÆ host:11434
#   whisper-stt ŌåÆ Faster-Whisper STT     ŌåÆ host:8000
#
# Host pre-requisites:
#   - Proprietary NVIDIA driver + nvidia-container-toolkit (nvidia-docker)
#   - `nvidia` container runtime registered with Docker (default after toolkit setup)
#
# First model pull (example):
#   docker compose exec ollama pull dolphin-llama3:8b
#
# Validation:
#   docker compose logs -f ollama
#   curl -s http://localhost:11434/api/tags
# ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ

services:

  # ŌöĆŌöĆ 1. Ollama (NVIDIA CUDA) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
  ollama:
    image: ollama/ollama:latest
    container_name: spirit-ollama
    restart: unless-stopped
    runtime: nvidia
    ports:
      - "11434:11434"
    volumes:
      - ollama_data:/root/.ollama
    environment:
      - NVIDIA_VISIBLE_DEVICES=all
      - NVIDIA_DRIVER_CAPABILITIES=compute,utility
      - OLLAMA_HOST=0.0.0.0:11434
      - OLLAMA_KEEP_ALIVE=24h
    deploy:
      resources:
        reservations:
          devices:
           - driver: nvidia
             count: all
             capabilities: [gpu]
    networks:
      - spirit-net
    healthcheck:
      # Official image is Ubuntu + `ollama` only (no curl); CLI talks to the local daemon.
      test: ["CMD-SHELL", "ollama list >/dev/null 2>&1 || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 40s               # GPU init takes longer than CPU ŌĆö allow extra time

  # ŌöĆŌöĆ 2. Faster-Whisper STT API ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
  #   OpenAI-compatible transcription endpoint:
  #     POST /v1/audio/transcriptions
  #          form-data: file=<audio blob>, model=<model name>
  #          returns:   { "text": "..." }
  #
  #   Model is downloaded on first start (~150 MB for base.en).
  #   For a beefier model set WHISPER__MODEL=large-v3 (slower, more accurate).
  whisper-stt:
    image: fedirz/faster-whisper-server:0.6.0-rc.3-cuda
    container_name: spirit-whisper
    restart: unless-stopped
    runtime: nvidia
    ports:
      - "8000:8000"
    environment:
      - NVIDIA_VISIBLE_DEVICES=all
      - NVIDIA_DRIVER_CAPABILITIES=compute,utility
      - WHISPER__MODEL=Systran/faster-whisper-base.en
      - WHISPER__LANGUAGE=en
      - WHISPER__DEVICE=cuda
    volumes:
      - whisper_cache:/root/.cache/huggingface
    networks:
      - spirit-net
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 30s

  # ŌöĆŌöĆ 3. Piper TTS (openedai-speech, CPU) ŌĆö OpenAI-compatible /v1/audio/speech ŌöĆ
  #   Maps OpenAI voice names ŌåÆ Piper ONNX models (see openedai-config/voice_to_speaker.yaml).
  #   Host port 5200 ŌåÆ container 8000. First start downloads voice models (~minutes on slow links).
  openedai-speech:
    image: ghcr.io/matatonic/openedai-speech-min:latest
    container_name: spirit-openedai-speech
    restart: unless-stopped
    ports:
      - "5200:8000"
    environment:
      - TTS_HOME=/app/voices
      - HF_HOME=/app/voices
    volumes:
      - openedai_voices:/app/voices
      - ./openedai-config/voice_to_speaker.yaml:/app/config/voice_to_speaker.yaml:ro
    command:
      - /bin/sh
      - -c
      - |
        set -e
        cd /app
        piper --data-dir voices --download-dir voices --model en_GB-alba-medium < /dev/null || true
        exec bash startup.min.sh
    networks:
      - spirit-net
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 90s

volumes:
  ollama_data:
  whisper_cache:
  openedai_voices:

networks:
  spirit-net:
    driver: bridge
</file>

