    font-family: var(--font-mono), ui-monospace, monospace;
    font-feature-settings: "kern" 0, "liga" 0;
  }
}

/* ── Homelab Design System - keyframes ──────────────────────────────────── */

@keyframes hl-track-pulse {
  0%, 100% { opacity: 0.55; }
  50% { opacity: 1; }
}
@keyframes hl-bar-glow {
  0%, 100% { filter: brightness(1) saturate(1); }
  50% { filter: brightness(1.14) saturate(1.1); }
}
@keyframes hl-bar-sheen {
  to { transform: translateX(200%); }
}
@keyframes hl-status-glow {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.14); filter: brightness(1.22); }
}
@keyframes hl-tag-glow {
  0%, 100% { filter: brightness(1); }
  50% { filter: brightness(1.12); }
}
@keyframes hl-tag-sheen {
  to { transform: translateX(160%); }
}
@keyframes hl-badge-pulse {
  to { box-shadow: 0 0 0 7px transparent; }
}

@layer utilities {
  /* Glass panel - layered depth */
  .homelab-panel {
    position: relative;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.052) 0%, rgba(255,255,255,0.018) 45%, rgba(255,255,255,0.012) 100%),
      color-mix(in oklab, var(--spirit-bg) 88%, transparent);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.06),
      0 2px 4px rgba(0,0,0,0.45),
      0 20px 48px -24px rgba(0,0,0,0.85);
    backdrop-filter: blur(22px) saturate(140%);
    overflow: hidden;
  }
  /** Slimmer glass slab - nodes strip only (still reads Homelab, less podium) */
  .homelab-panel--dense {
    border-radius: 14px;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.055),
      0 1px 2px rgba(0,0,0,0.38),
      0 10px 28px -16px rgba(0,0,0,0.72);
    backdrop-filter: blur(16px) saturate(132%);
  }
  .homelab-panel-accent {
    border-color: color-mix(in oklab, var(--spirit-accent) 36%, transparent);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.07),
      0 2px 4px rgba(0,0,0,0.45),
      0 32px 80px -40px color-mix(in oklab, var(--spirit-accent) 45%, transparent);
  }

  /* Progress bar track */
  .homelab-progress {
    position: relative;
    height: 7px;
    border-radius: 9999px;
    background: rgba(0,0,0,0.40);
    box-shadow: inset 0 1px 1px rgba(0,0,0,0.62);
    overflow: hidden;
  }
  .homelab-progress::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      transparent var(--hl-pct, 0%),
      color-mix(in oklab, var(--spirit-accent) 22%, transparent) var(--hl-pct, 0%),
      color-mix(in oklab, var(--spirit-accent) 10%, transparent) 100%
    );
    animation: hl-track-pulse 2.8s ease-in-out infinite;
  }

  /* Progress bar fill */
  .homelab-progress-fill {
    position: absolute;
    top: 0; bottom: 0; left: 0;
    border-radius: 9999px;
    background: linear-gradient(90deg, color-mix(in oklab, var(--spirit-accent) 60%, #000), var(--spirit-accent));
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.22);
    animation: hl-bar-glow 2.6s ease-in-out infinite;
    overflow: hidden;
  }
  .homelab-progress-fill::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(100deg, transparent 15%, rgba(255,255,255,0.30) 50%, transparent 85%);
    transform: translateX(-100%);
    animation: hl-bar-sheen 2.9s linear infinite;
  }
  .homelab-progress-fill--good {
    background: linear-gradient(90deg, oklch(0.44 0.16 160), oklch(0.76 0.16 160));
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.22);
  }
  .homelab-progress-fill--warn {
    background: linear-gradient(90deg, oklch(0.50 0.16 80), oklch(0.82 0.14 80));
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.22);
  }
  .homelab-progress-fill--bad {
    background: linear-gradient(90deg, oklch(0.44 0.20 25), oklch(0.70 0.20 25));
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.22);
  }

  /* Animated status dot */
  .homelab-status-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    background: oklch(0.74 0.16 160);
    box-shadow: 0 0 10px oklch(0.74 0.16 160 / 0.85), 0 0 0 3px oklch(0.74 0.16 160 / 0.14);
