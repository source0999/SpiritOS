<file path="src/lib/hooks/useSpiritVisualViewportVars.ts">
"use client";

// ── useSpiritVisualViewportVars - iOS Safari keyboard: layout viewport lies, VV doesn’t ─
// > 100dvh is cosplay on mobile WebKit. Drive shell height from visualViewport + rAF coalesce.
// > Keyboard inset state is effect-only — safe for SSR (starts at 0).
import { type RefObject, useEffect, useRef, useState } from "react";

export type SpiritVisualViewportVarTarget = RefObject<HTMLElement | null>;

export type SpiritVisualViewportMetrics = {
  /** Rounded px; updated from visualViewport inside useEffect only. */
  keyboardInsetPx: number;
};

/**
 * Paints CSS custom properties on `ref.current` for mobile keyboard-safe layouts.
 * - `--spirit-visual-viewport-height` — `visualViewport.height` when keyboard is open; when the
 *   keyboard lane is idle, **pinned to `window.innerHeight`** (same as vv on stable loads, but
 *   we stop listening to VV resize/scroll so iOS PTR rubber-band cannot spam `apply()`).
 * - `--spirit-keyboard-inset` — max(0, layout height − visible height − vv.offsetTop)
 * - `--spirit-visual-offset-top` — raw offset **clamped to 0** when keyboard lane is idle
 *
 * **PTR / rubber-band:** (1) `visualViewport` `resize`/`scroll` listeners stay detached while the
 * keyboard lane is idle. (2) Inset must stay ≥ 14px for **50ms** before we treat the lane as
 * active (ignores one-frame PTR spikes). (3) Identical CSS triple + lane state skips redundant
 * `setProperty` when `window.resize` fires in a tight loop.
 */
export function useSpiritVisualViewportVars(
  ref: SpiritVisualViewportVarTarget,
  enabled = true,
): SpiritVisualViewportMetrics {
  const [keyboardInsetPx, setKeyboardInsetPx] = useState(0);
  const lastInsetRef = useRef(0);
  const prevSigRef = useRef({ vh: -1, ot: -1, ki: -1 });

  useEffect(() => {
    if (!enabled || typeof window === "undefined") return;
    const el = ref.current;
    if (!el) return;

    const vv = window.visualViewport ?? null;
    let raf = 0;
    let vvListenersAttached = false;
    /** Last schedule() source for NDJSON (PTR vs real resize). */
    let lastScheduleSource = "init";
    /** Sustained inset before we treat the keyboard lane as active (avoids PTR spikes). */
    let keyboardLaneActive = false;
    let armKbTimer: number | null = null;
    let prevLaneIdleForLog = true;
    let lastStyleTriple = "";
    let lastRLogAt = 0;
    let redundantApplyBurst = 0;

    const clearKbArmTimer = () => {
      if (armKbTimer != null) {
        window.clearTimeout(armKbTimer);
        armKbTimer = null;
      }
    };

    const schedule = (source: string) => {
      lastScheduleSource = source;
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(apply);
    };

    const onWinResize = () => schedule("window-resize");
    const onOrientation = () => schedule("orientationchange");
    const onFocusIn = () => schedule("focusin");
    const onFocusOut = () => schedule("focusout");
    const onVvResize = () => schedule("vv-resize");
    const onVvScroll = () => schedule("vv-scroll");

    const setVvListeners = (laneIdle: boolean) => {
      if (!vv) return;
      if (laneIdle && vvListenersAttached) {
        vv.removeEventListener("resize", onVvResize);
        vv.removeEventListener("scroll", onVvScroll);
        vvListenersAttached = false;
        // #region agent log
        fetch("http://localhost:7530/ingest/da155463-47fd-4bed-94cb-233903115f13", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-Debug-Session-Id": "d22b1b",
          },
          body: JSON.stringify({
            sessionId: "d22b1b",
            hypothesisId: "M",
            location: "useSpiritVisualViewportVars.ts:setVvListeners",
            message: "Detached visualViewport resize/scroll (keyboard lane idle / anti-PTR)",
            data: {},
            timestamp: Date.now(),
          }),
        }).catch(() => {});
        console.info("AGENT_DEBUG_PTR", { hypothesisId: "M", vvListeners: "detached" });
        // #endregion
      } else if (!laneIdle && !vvListenersAttached) {
        vv.addEventListener("resize", onVvResize);
        vv.addEventListener("scroll", onVvScroll);
        vvListenersAttached = true;
        // #region agent log
        fetch("http://localhost:7530/ingest/da155463-47fd-4bed-94cb-233903115f13", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-Debug-Session-Id": "d22b1b",
          },
          body: JSON.stringify({
            sessionId: "d22b1b",
            hypothesisId: "M",
            location: "useSpiritVisualViewportVars.ts:setVvListeners",
            message: "Attached visualViewport resize/scroll (keyboard lane active)",
            data: {},
            timestamp: Date.now(),
          }),
        }).catch(() => {});
        console.info("AGENT_DEBUG_PTR", { hypothesisId: "M", vvListeners: "attached" });
        // #endregion
      }
    };

    function apply() {
      const node = ref.current;
      if (!node) return;
      const innerH = window.innerHeight;
      let vh = innerH;
      let offsetTop = 0;
      let keyboardInset = 0;
      let rawOffsetTop = 0;
      if (vv) {
        vh = vv.height;
        rawOffsetTop = vv.offsetTop;
        keyboardInset = Math.max(0, innerH - vh - rawOffsetTop);
        offsetTop = keyboardInset < 14 ? 0 : rawOffsetTop;
      }

      // ── Keyboard lane hysteresis: PTR can briefly inflate inset without a real keyboard.
      // Require inset ≥ 14 for 50ms before attaching VV / switching to vv.height paint path.
      if (keyboardInset < 14) {
        clearKbArmTimer();
        if (keyboardLaneActive) {
          keyboardLaneActive = false;
        }
      } else if (!keyboardLaneActive && armKbTimer == null) {
        armKbTimer = window.setTimeout(() => {
          armKbTimer = null;
          if (!vv) return;
          const ih = window.innerHeight;
          const insNow = Math.max(0, ih - vv.height - vv.offsetTop);
          if (insNow >= 14) {
            keyboardLaneActive = true;
            // #region agent log
            fetch("http://localhost:7530/ingest/da155463-47fd-4bed-94cb-233903115f13", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                "X-Debug-Session-Id": "d22b1b",
              },
              body: JSON.stringify({
                sessionId: "d22b1b",
                hypothesisId: "S",
                location: "useSpiritVisualViewportVars.ts:kbArm",
                message: "Keyboard lane armed after sustained inset (not PTR spike)",
                data: { insetNow: Math.round(insNow) },
                timestamp: Date.now(),
              }),
            }).catch(() => {});
            console.info("AGENT_DEBUG_PTR", { hypothesisId: "S", phase: "kb-armed", inset: Math.round(insNow) });
            // #endregion
            schedule("kb-armed");
          }
        }, 50);
      }

      const keyboardLaneIdle = !keyboardLaneActive;
      const paintVh = keyboardLaneIdle ? innerH : vh;

      const styleTriple = `${paintVh}|${keyboardInset}|${offsetTop}|${keyboardLaneActive ? 1 : 0}`;
      if (styleTriple === lastStyleTriple) {
        redundantApplyBurst += 1;
        const now = Date.now();
        if (now - lastRLogAt > 400) {
          lastRLogAt = now;
          // #region agent log
          fetch("http://localhost:7530/ingest/da155463-47fd-4bed-94cb-233903115f13", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "X-Debug-Session-Id": "d22b1b",
            },
            body: JSON.stringify({
              sessionId: "d22b1b",
              hypothesisId: "R",
              location: "useSpiritVisualViewportVars.ts:apply",
              message: "Skipped redundant setProperty (same triple)",
              data: {
                burst: redundantApplyBurst,
                lastScheduleSource,
                keyboardLaneIdle,
              },
              timestamp: now,
            }),
          }).catch(() => {});
          console.info("AGENT_DEBUG_PTR", {
            hypothesisId: "R",
            burst: redundantApplyBurst,
            lastScheduleSource,
            keyboardLaneIdle,
          });
          // #endregion
          redundantApplyBurst = 0;
        }
        return;
      }
      lastStyleTriple = styleTriple;

      node.style.setProperty("--spirit-visual-viewport-height", `${paintVh}px`);
      node.style.setProperty("--spirit-keyboard-inset", `${keyboardInset}px`);
      node.style.setProperty("--spirit-visual-offset-top", `${offsetTop}px`);

      setVvListeners(keyboardLaneIdle);

      if (keyboardLaneIdle !== prevLaneIdleForLog) {
        prevLaneIdleForLog = keyboardLaneIdle;
        // #region agent log
        fetch("http://localhost:7530/ingest/da155463-47fd-4bed-94cb-233903115f13", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-Debug-Session-Id": "d22b1b",
          },
          body: JSON.stringify({
            sessionId: "d22b1b",
            hypothesisId: "S",
            location: "useSpiritVisualViewportVars.ts:laneFlip",
            message: "keyboardLaneIdle flipped",
            data: {
              keyboardLaneIdle,
              keyboardInset: Math.round(keyboardInset),
              lastScheduleSource,
            },
            timestamp: Date.now(),
          }),
        }).catch(() => {});
        console.info("AGENT_DEBUG_PTR", {
          hypothesisId: "S",
          phase: "lane-flip",
          keyboardLaneIdle,
          keyboardInset: Math.round(keyboardInset),
          lastScheduleSource,
        });
        // #endregion
      }

      // #region agent log
      const rvh = Math.round(paintVh);
      const rot = Math.round(offsetTop);
      const rki = Math.round(keyboardInset);
      if (
        rvh !== prevSigRef.current.vh ||
        rot !== prevSigRef.current.ot ||
        rki !== prevSigRef.current.ki
      ) {
        prevSigRef.current = { vh: rvh, ot: rot, ki: rki };
        fetch("http://localhost:7530/ingest/da155463-47fd-4bed-94cb-233903115f13", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-Debug-Session-Id": "d22b1b",
          },
          body: JSON.stringify({
            sessionId: "d22b1b",
            hypothesisId: "L",
            location: "useSpiritVisualViewportVars.ts:apply",
            message: "VV paint (height may pin to innerH when keyboard idle)",
            data: {
              paintVh: rvh,
              vvHeight: vv ? Math.round(vh) : null,
              heightPinnedToInner: keyboardLaneIdle,
              vvListenersAttached,
              offsetTop: rot,
              rawOffsetTop: vv ? Math.round(rawOffsetTop) : null,
              offsetTopClamped: vv ? Math.round(rawOffsetTop) !== rot : false,
              keyboardInset: rki,
              innerH: Math.round(innerH),
              scrollY: Math.round(window.scrollY),
              docElScrollTop: Math.round(document.documentElement.scrollTop),
              lastScheduleSource,
              keyboardLaneActive,
            },
            timestamp: Date.now(),
          }),
        }).catch(() => {});
        console.info("AGENT_DEBUG_PTR", {
          hypothesisId: "L",
          paintVh: rvh,
          vvH: vv ? Math.round(vh) : null,
          pinned: keyboardLaneIdle,
          vvListenersAttached,
          offsetTop: rot,
          rawOt: vv ? Math.round(rawOffsetTop) : null,
          clamped: vv ? Math.round(rawOffsetTop) !== rot : false,
          keyboardInset: rki,
          innerH: Math.round(innerH),
        });
      }
      // #endregion

      const rounded = Math.round(keyboardInset);
      if (rounded !== lastInsetRef.current) {
        lastInsetRef.current = rounded;
        setKeyboardInsetPx(rounded);
      }
    }

    window.addEventListener("resize", onWinResize);
    window.addEventListener("orientationchange", onOrientation);
    document.addEventListener("focusin", onFocusIn);
    document.addEventListener("focusout", onFocusOut);

    schedule("mount");

    return () => {
      clearKbArmTimer();
      cancelAnimationFrame(raf);
      if (vv && vvListenersAttached) {
        vv.removeEventListener("resize", onVvResize);
        vv.removeEventListener("scroll", onVvScroll);
        vvListenersAttached = false;
      }
      window.removeEventListener("resize", onWinResize);
      window.removeEventListener("orientationchange", onOrientation);
      document.removeEventListener("focusin", onFocusIn);
      document.removeEventListener("focusout", onFocusOut);
    };
  }, [ref, enabled]);

  return { keyboardInsetPx };
}
