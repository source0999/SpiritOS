    $('#densitySelect').addEventListener('change', e => document.body.dataset.density = e.target.value);
    function bindSwitch(id, attr) { const el = $(id); el.addEventListener('click', () => { const next = el.getAttribute('aria-checked') !== 'true'; el.setAttribute('aria-checked', String(next)); document.body.dataset[attr] = next ? 'on' : 'off'; }); }
    bindSwitch('#quarantineSwitch', 'quarantine'); bindSwitch('#grainSwitch', 'grain');
