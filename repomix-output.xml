    @keyframes barGlow { 50% { filter: brightness(1.15) saturate(1.12); box-shadow: inset 0 1px 0 rgb(255 255 255 / .24), 0 0 14px color-mix(in oklch, var(--spirit-500) 70%, transparent); } }
