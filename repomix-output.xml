/* ─────────── Chat preview bubbles ─────────── */
.spirit-demo-root .demo-chat-rail {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  min-height: 0;
}
.spirit-demo-root .demo-chat-rail__head {
