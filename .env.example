# Groq primary backend (OpenAI-compatible API).
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# Optional model override (default in route.ts: llama-3.1-8b-instant)
# GROQ_MODEL=llama-3.1-8b-instant

# Ollama fallback backend (used when Groq key is missing/unreachable).
OLLAMA_BASE_URL=http://localhost:11434
# Spirit UI `/api/spirit` (AI SDK → OpenAI-compat): optional explicit OpenAI base (no trailing slash).
# If unset, derived from OLLAMA_BASE_URL → …/v1
OLLAMA_OPENAI_BASE_URL=
# Model tag on the Ollama host (default in app: hermes4).
OLLAMA_MODEL=hermes4
# Local Ollama ignores this for auth; required shape for the OpenAI client.
OLLAMA_API_KEY=ollama
# Max tokens per assistant reply from `/api/spirit` (streamText); defaults to 1024 if unset.
SPIRIT_MAX_OUTPUT_TOKENS=1024
# Optional: host-side context window when set on Ollama (see host Modelfile / launch flags).
# Unset → diagnostics show “Host default”; do not imply ~8k unless this is set.
# OLLAMA_NUM_CTX=8192

# Piper TTS (openedai-speech) — local OpenAI-compatible speech API (no OpenAI key).
PIPER_TTS_URL=http://localhost:5200
# OpenAI-style alias: `fable` is mapped to British female (en_GB-alba) in backend/openedai-config/voice_to_speaker.yaml
PIPER_TTS_VOICE=fable

# Optional: legacy cloud TTS if you proxy elsewhere (Spirit chat uses Piper by default).
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_TTS_VOICE=nova
