# Groq primary backend (OpenAI-compatible API).
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# Optional model override (default in route.ts: llama-3.1-8b-instant)
# GROQ_MODEL=llama-3.1-8b-instant

# Ollama fallback backend (used when Groq key is missing/unreachable).
OLLAMA_BASE_URL=http://localhost:11434
# Spirit UI `/api/spirit` (AI SDK → OpenAI-compat): optional explicit OpenAI base (no trailing slash).
# If unset, derived from OLLAMA_BASE_URL → …/v1
OLLAMA_OPENAI_BASE_URL=
# Model tag on the Ollama host (default in app: hermes4).
OLLAMA_MODEL=hermes4
# Optional: faster model for `/oracle` only (defaults to OLLAMA_MODEL when unset).
# ORACLE_OLLAMA_MODEL=hermes3:8b
# Optional: max output tokens for the Oracle lane (defaults to SPIRIT_MAX_OUTPUT_TOKENS).
# ORACLE_MAX_OUTPUT_TOKENS=768
# Local Ollama ignores this for auth; required shape for the OpenAI client.
OLLAMA_API_KEY=ollama
# Max tokens per assistant reply from `/api/spirit` (streamText); defaults to 1024 if unset.
SPIRIT_MAX_OUTPUT_TOKENS=1024
# Optional: host-side context window when set on Ollama (see host Modelfile / launch flags).
# Unset → diagnostics show “Host default”; do not imply ~8k unless this is set.
# OLLAMA_NUM_CTX=8192

# TTS: `piper` (default) or `elevenlabs` (same-origin `/api/tts` only; never expose keys to the browser).
TTS_PROVIDER=piper

# Piper TTS (openedai-speech) - local OpenAI-compatible speech API (no OpenAI key).
PIPER_TTS_URL=http://localhost:5200
# OpenAI-style alias: `fable` is mapped to British female (en_GB-alba) in backend/openedai-config/voice_to_speaker.yaml
PIPER_TTS_VOICE=fable

# ElevenLabs (optional high-quality TTS when TTS_PROVIDER=elevenlabs)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=fgDJOgmENIR82PueQrVs
# Optional default for Voice picker + synthesis when client sends no voiceId (prefer over ELEVENLABS_VOICE_ID).
# ELEVENLABS_DEFAULT_VOICE_ID=
# ELEVENLABS_DEFAULT_VOICE_NAME=Clarice
# Recommended (no catalog permission needed): `Name:voice_id` - id is non-empty, alphanumeric-ish, typically 10+ chars after last `:`.
# ELEVENLABS_VOICE_ALLOWLIST=Clarice:your_voice_id_here,Charlotte:other_id_here
# Name-only (comma-separated names): needs working ElevenLabs catalog (`voices_read`); if catalog fails, switch to Name:voice_id above.
# ELEVENLABS_VOICE_ALLOWLIST=Charlotte,Clarice,Minerva Nightshade,Paige
# ELEVENLABS_VOICE_ALLOWLIST_JSON wins if both are set. JSON example:
# ELEVENLABS_VOICE_ALLOWLIST_JSON=[{"name":"Clarice","voice_id":"abc..."},{"name":"Charlotte","voice_id":"def..."}]
# Comma explicit form (display name may contain colons only if JSON): Clarice:id1,Charlotte – Warm:id2
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# ElevenLabs voice_settings.speed default (0.7–1.2); Voice settings UI can override per request.
# ELEVENLABS_VOICE_SPEED=1.12

# Optional: legacy cloud TTS if you proxy elsewhere (Spirit chat uses Piper by default).
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_TTS_VOICE=nova

# Prompt 10B - OpenAI Responses `web_search` (Researcher + POST /api/research/web-search).
# OPENAI_API_KEY must be set for web search. Keys never go to the browser.
# WEB_SEARCH_ENABLED=true
# WEB_SEARCH_MODEL=gpt-4o
# WEB_SEARCH_MAX_RESULTS=8
# WEB_SEARCH_TOOL_TYPE=web_search
