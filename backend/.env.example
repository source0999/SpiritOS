# Copy this file to .env and fill in values if you need to override defaults.
# These env vars are consumed by /frontend/.env.local for the Next.js API route.

# ── Service URLs (accessible from the Next.js host) ──────────────────────────
OLLAMA_URL=http://localhost:11434
XTTS_URL=http://localhost:8020
WHISPER_URL=http://localhost:8000

# ── Ollama model to use (must be pulled first via `ollama pull <model>`) ──────
OLLAMA_MODEL=llama3
