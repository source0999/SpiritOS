# Groq primary backend (OpenAI-compatible API).
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# Optional model override (default in route.ts: llama-3.1-8b-instant)
# GROQ_MODEL=llama-3.1-8b-instant

# Ollama fallback backend (used when Groq key is missing/unreachable).
OLLAMA_BASE_URL=http://localhost:11434
# Same model as backend / Ollama host (must be pulled on the Ollama machine).
# OLLAMA_MODEL=dolphin-llama3:8b
# OLLAMA_NUM_CTX=8192

# OpenAI cloud TTS backend.
OPENAI_API_KEY=your_openai_api_key_here
# Optional voice override (default in route.ts: nova)
# OPENAI_TTS_VOICE=nova
